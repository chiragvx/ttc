# Normalize all text to LF in the repo so the Linux container/CI (Makefile, Dockerfile, shell,
# Python) never sees CRLF. Working trees may check out CRLF on Windows; the repo stays LF.
* text=auto eol=lf

# Keep these strictly LF (CRLF breaks them on Linux)
Makefile  text eol=lf
*.sh      text eol=lf
Dockerfile* text eol=lf

# Binary
*.png binary
*.jpg binary
*.step binary
