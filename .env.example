# Copy to `.env` and fill in. The runtime LLM delta-emitter uses OpenRouter (OpenAI-compatible).
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=

# Optional overrides:
OPENROUTER_MODEL=deepseek/deepseek-chat
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Shared secret gating who can create a new session on this deployment (2026-07-15). Unset (the
# default) = open, matching pre-auth local-dev behavior — set this before exposing the app beyond
# localhost (e.g. `docker compose up` binds 0.0.0.0:8000). Enter the SAME value in the frontend's
# Settings modal ("Server auth token"). Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=

# Postgres connection string — durable event/verdict/job-status storage AND packages/catalog's
# reference-data tables (2026-07-15). Unset (the default) = everything falls back to in-memory /
# seed-file storage, zero infrastructure needed. docker-compose.yml already sets this for the
# backend/worker services; only needed here for running `python -m packages.catalog.seed` or the
# app directly against a local/hosted Postgres outside compose.
# DATABASE_URL=postgresql://postgres:cad@localhost:5432/cad
